{
  "database": {
    "dev": "SQLite (fichier local) avec SQLAlchemy ORM",
    "prod": "PostgreSQL 15 avec SQLAlchemy ORM (m\u00eame mod\u00e8les que SQLite)",
    "models": [
      {
        "name": "User",
        "fields": {
          "id": "Integer (Primary Key)",
          "email": "String (Unique, Index)",
          "hashed_password": "String (bcrypt)",
          "created_at": "DateTime (default=now)"
        }
      },
      {
        "name": "Task",
        "fields": {
          "id": "Integer (Primary Key)",
          "title": "String (max_length=255)",
          "description": "Text (nullable)",
          "status": "Enum('todo', 'in_progress', 'done')",
          "priority": "Enum('low', 'medium', 'high')",
          "created_at": "DateTime (default=now)",
          "updated_at": "DateTime (onupdate=now)",
          "user_id": "Integer (ForeignKey: User.id)"
        },
        "relations": [
          "Many-to-One avec User"
        ]
      }
    ],
    "indexes": [
      "CREATE INDEX idx_task_user_id ON task(user_id)",
      "CREATE INDEX idx_task_status ON task(status)"
    ]
  },
  "backend": {
    "framework": "FastAPI (Python 3.10)",
    "structure": {
      "routers": [
        {
          "name": "auth",
          "endpoints": [
            {
              "path": "/register",
              "method": "POST",
              "description": "Inscription utilisateur"
            },
            {
              "path": "/login",
              "method": "POST",
              "description": "Connexion avec JWT"
            }
          ]
        },
        {
          "name": "tasks",
          "endpoints": [
            {
              "path": "/tasks",
              "method": "GET",
              "description": "Liste des t\u00e2ches avec filtres (status, priority)"
            },
            {
              "path": "/tasks",
              "method": "POST",
              "description": "Cr\u00e9er une t\u00e2che"
            },
            {
              "path": "/tasks/{id}",
              "method": "PUT",
              "description": "Modifier une t\u00e2che"
            },
            {
              "path": "/tasks/{id}",
              "method": "DELETE",
              "description": "Supprimer une t\u00e2che"
            }
          ]
        }
      ],
      "dependencies": {
        "jwt": "python-jose[cryptography] + passlib[bcrypt]",
        "database": "SQLAlchemy + asyncpg (pour PostgreSQL)",
        "env": "pydantic-settings pour gestion des variables d'environnement"
      }
    },
    "auth": {
      "approche": "JWT avec python-jose (RS256) et passlib (bcrypt pour hashage)",
      "token_expiry": "15 minutes (access token), 7 jours (refresh token)",
      "endpoints": [
        "/auth/refresh pour renouvellement"
      ]
    }
  },
  "frontend": {
    "framework": "React 18 + TypeScript",
    "libraries": {
      "ui": "Material-UI v5 ou TailwindCSS",
      "routing": "React Router v6",
      "state": "React Context ou Zustand (pour auth/tasks)",
      "forms": "React Hook Form + Zod pour validation"
    },
    "pages": [
      {
        "name": "LoginPage",
        "components": [
          "LoginForm",
          "RegisterLink"
        ]
      },
      {
        "name": "DashboardPage",
        "components": [
          "TaskList (avec filtres)",
          "TaskForm (modal)",
          "TaskItem (avec actions edit/delete)",
          "Navbar (avec user menu)"
        ]
      }
    ],
    "routing": {
      "public": [
        "/login",
        "/register"
      ],
      "protected": [
        "/dashboard",
        "/tasks/*"
      ]
    }
  },
  "auth": "JWT avec refresh tokens (HTTP-only cookies)",
  "cache": "None (peut \u00eatre ajout\u00e9 ult\u00e9rieurement avec Redis pour les t\u00e2ches fr\u00e9quentes)",
  "message_broker": "None",
  "container": {
    "docker": {
      "frontend": "Node 18 (multi-stage build)",
      "backend": "Python 3.10 (slim-bullseye)",
      "db": "PostgreSQL 15 (official image)"
    },
    "docker_compose": {
      "services": [
        "frontend",
        "backend",
        "db"
      ],
      "volumes": [
        "postgres_data pour persistance"
      ],
      "networks": [
        "todo_network"
      ]
    }
  },
  "cloud": "D\u00e9ploiement local pour d\u00e9veloppement, cible production: AWS ECS ou Render.com"
}