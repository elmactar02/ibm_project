{
  "database": {
    "technology": "PostgreSQL 15",
    "models": [
      {
        "name": "User",
        "fields": {
          "id": "UUID (primary key)",
          "email": "String (unique, index)",
          "hashed_password": "String",
          "created_at": "DateTime (default now)"
        }
      },
      {
        "name": "Task",
        "fields": {
          "id": "UUID (primary key)",
          "title": "String (max 255)",
          "description": "Text (nullable)",
          "status": "Enum('todo', 'in_progress', 'done')",
          "priority": "Enum('low', 'medium', 'high')",
          "due_date": "Date (nullable)",
          "user_id": "UUID (foreign key to User)",
          "created_at": "DateTime (default now)",
          "updated_at": "DateTime (on update)"
        },
        "relations": [
          "Many-to-One avec User (user_id)"
        ]
      }
    ],
    "indexes": [
      "CREATE INDEX idx_task_user_status ON task(user_id, status)",
      "CREATE INDEX idx_task_user_priority ON task(user_id, priority)"
    ]
  },
  "backend": {
    "framework": "FastAPI",
    "auth": {
      "jwt": {
        "secret_key": "G\u00e9n\u00e9r\u00e9 via secrets.token_urlsafe(32)",
        "algorithm": "HS256",
        "access_token_expire_minutes": 30
      },
      "password_hashing": "bcrypt via passlib"
    },
    "routers": [
      {
        "name": "auth",
        "endpoints": [
          {
            "method": "POST",
            "path": "/register",
            "description": "Inscription utilisateur"
          },
          {
            "method": "POST",
            "path": "/token",
            "description": "Connexion et g\u00e9n\u00e9ration JWT"
          }
        ]
      },
      {
        "name": "tasks",
        "endpoints": [
          {
            "method": "GET",
            "path": "/tasks",
            "description": "Liste des t\u00e2ches avec filtres (status, priority)"
          },
          {
            "method": "POST",
            "path": "/tasks",
            "description": "Cr\u00e9ation d'une t\u00e2che"
          },
          {
            "method": "PUT",
            "path": "/tasks/{task_id}",
            "description": "Modification d'une t\u00e2che"
          },
          {
            "method": "DELETE",
            "path": "/tasks/{task_id}",
            "description": "Suppression d'une t\u00e2che"
          }
        ]
      }
    ],
    "middleware": [
      "CORS",
      "JWT validation pour routes prot\u00e9g\u00e9es"
    ]
  },
  "frontend": {
    "framework": "React 18 + TypeScript",
    "state_management": "React Context + useReducer",
    "routing": "React Router v6",
    "ui_library": "Material-UI v5",
    "components": [
      {
        "name": "AuthLayout",
        "pages": [
          "LoginPage",
          "RegisterPage"
        ],
        "features": [
          "Formulaires avec validation",
          "Redirection apr\u00e8s connexion"
        ]
      },
      {
        "name": "DashboardLayout",
        "pages": [
          "TaskListPage",
          "TaskDetailPage"
        ],
        "features": [
          "Tableau de bord avec filtres (status/priority)",
          "Liste des t\u00e2ches avec drag-and-drop (optionnel)",
          "Modale pour cr\u00e9ation/modification",
          "Confirmation pour suppression"
        ]
      },
      {
        "name": "Shared",
        "components": [
          "Navbar",
          "PrivateRoute",
          "ErrorBoundary"
        ]
      }
    ],
    "api_client": "Axios avec interceptors pour JWT"
  },
  "auth": "JWT avec python-jose + passlib (bcrypt)",
  "cache": "None (Redis \u00e0 ajouter si besoin de performance)",
  "message_broker": "None",
  "container": {
    "docker": {
      "files": [
        "Dockerfile pour backend",
        "Dockerfile pour frontend",
        "docker-compose.yml"
      ],
      "services": {
        "backend": {
          "port": 8000,
          "depends_on": [
            "db"
          ]
        },
        "frontend": {
          "port": 3000,
          "depends_on": [
            "backend"
          ]
        },
        "db": {
          "image": "postgres:15",
          "volumes": [
            "postgres_data:/var/lib/postgresql/data"
          ]
        }
      }
    },
    "ci_cd": {
      "github_actions": {
        "workflows": [
          {
            "name": "test-and-deploy",
            "triggers": [
              "push sur main",
              "pull_request"
            ],
            "jobs": {
              "test": {
                "backend": "pytest + coverage",
                "frontend": "jest + testing-library"
              },
              "build": {
                "backend": "docker build -t todo-app-backend .",
                "frontend": "docker build -t todo-app-frontend ."
              },
              "deploy": {
                "condition": "push sur main",
                "steps": [
                  "docker push vers registry",
                  "d\u00e9ploiement sur serveur cible"
                ]
              }
            }
          }
        ]
      }
    }
  },
  "cloud": "D\u00e9ploiement local pour d\u00e9veloppement, cible AWS ECS ou Heroku pour production"
}