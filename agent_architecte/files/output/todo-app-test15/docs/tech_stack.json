{
  "database": {
    "technology": "PostgreSQL 15",
    "models": [
      {
        "name": "User",
        "fields": {
          "id": "Integer (Primary Key)",
          "email": "String (Unique, 255 chars)",
          "hashed_password": "String (255 chars)",
          "created_at": "DateTime (default: now)"
        },
        "relations": []
      },
      {
        "name": "Task",
        "fields": {
          "id": "Integer (Primary Key)",
          "title": "String (255 chars)",
          "description": "Text (nullable)",
          "status": "Enum ('todo', 'in_progress', 'done')",
          "priority": "Enum ('low', 'medium', 'high')",
          "created_at": "DateTime (default: now)",
          "updated_at": "DateTime (on update)",
          "user_id": "Integer (Foreign Key: User.id)"
        },
        "relations": [
          "Many-to-One avec User"
        ]
      }
    ],
    "instructions": "1. Cr\u00e9er les mod\u00e8les SQLAlchemy avec les champs exacts ci-dessus. 2. Configurer les relations avec `back_populates`. 3. Ajouter des indexes sur `user_id`, `status` et `priority` pour optimiser les filtres. 4. Utiliser Alembic pour les migrations."
  },
  "backend": {
    "technology": "FastAPI (Python 3.10)",
    "endpoints": [
      {
        "path": "/auth/register",
        "method": "POST",
        "description": "Inscription utilisateur (email + mot de passe)",
        "auth_required": false,
        "request_body": {
          "email": "string",
          "password": "string"
        },
        "response": {
          "access_token": "string",
          "token_type": "string"
        }
      },
      {
        "path": "/auth/login",
        "method": "POST",
        "description": "Connexion utilisateur (JWT)",
        "auth_required": false,
        "request_body": {
          "email": "string",
          "password": "string"
        },
        "response": {
          "access_token": "string",
          "token_type": "string"
        }
      },
      {
        "path": "/tasks",
        "method": "GET",
        "description": "Lister les t\u00e2ches avec filtres (status, priority)",
        "auth_required": true,
        "query_params": {
          "status": "optional enum",
          "priority": "optional enum"
        },
        "response": {
          "tasks": "array of Task objects"
        }
      },
      {
        "path": "/tasks",
        "method": "POST",
        "description": "Cr\u00e9er une t\u00e2che",
        "auth_required": true,
        "request_body": {
          "title": "string",
          "description": "optional string",
          "status": "enum",
          "priority": "enum"
        },
        "response": {
          "task": "Task object"
        }
      },
      {
        "path": "/tasks/{task_id}",
        "method": "PUT",
        "description": "Modifier une t\u00e2che",
        "auth_required": true,
        "request_body": {
          "title": "optional string",
          "description": "optional string",
          "status": "optional enum",
          "priority": "optional enum"
        },
        "response": {
          "task": "Task object"
        }
      },
      {
        "path": "/tasks/{task_id}",
        "method": "DELETE",
        "description": "Supprimer une t\u00e2che",
        "auth_required": true,
        "response": {
          "detail": "string"
        }
      }
    ],
    "auth": {
      "approach": "JWT avec python-jose (jose) + passlib (bcrypt)",
      "token_expiry": "30 minutes",
      "refresh_tokens": false,
      "security_schemes": {
        "OAuth2PasswordBearer": {
          "tokenUrl": "/auth/login",
          "scopes": {}
        }
      }
    },
    "instructions": "1. Structurer le projet en routers (auth/tasks) et services (users/tasks). 2. Impl\u00e9menter les endpoints avec validation Pydantic. 3. Configurer CORS pour le frontend. 4. Ajouter des tests unitaires avec pytest. 5. Utiliser `Depends` pour l'authentification JWT."
  },
  "frontend": {
    "technology": "React 18 + TypeScript + Vite",
    "components": [
      {
        "name": "AuthLayout",
        "description": "Layout pour les pages d'authentification (login/register)"
      },
      {
        "name": "DashboardLayout",
        "description": "Layout principal avec sidebar et header"
      },
      {
        "name": "TaskList",
        "description": "Liste des t\u00e2ches avec filtres (status/priority) et pagination"
      },
      {
        "name": "TaskForm",
        "description": "Formulaire pour cr\u00e9er/modifier une t\u00e2che (modal)"
      },
      {
        "name": "TaskCard",
        "description": "Carte individuelle pour une t\u00e2che (avec boutons d'action)"
      },
      {
        "name": "AuthProvider",
        "description": "Contexte React pour g\u00e9rer l'\u00e9tat d'authentification (JWT)"
      }
    ],
    "pages": [
      {
        "path": "/login",
        "component": "LoginPage",
        "description": "Page de connexion avec formulaire"
      },
      {
        "path": "/register",
        "component": "RegisterPage",
        "description": "Page d'inscription avec formulaire"
      },
      {
        "path": "/dashboard",
        "component": "DashboardPage",
        "description": "Tableau de bord avec liste des t\u00e2ches et filtres",
        "protected": true
      }
    ],
    "routing": {
      "library": "React Router v6",
      "protected_routes": [
        "/dashboard"
      ],
      "public_routes": [
        "/login",
        "/register"
      ]
    },
    "state_management": {
      "approach": "React Context + useReducer pour l'auth, Zustand pour les t\u00e2ches",
      "stores": [
        {
          "name": "useAuthStore",
          "description": "G\u00e8re l'\u00e9tat d'authentification (token, user)"
        },
        {
          "name": "useTasksStore",
          "description": "G\u00e8re les t\u00e2ches (CRUD, filtres)"
        }
      ]
    },
    "instructions": "1. Cr\u00e9er les composants avec TypeScript et interfaces pour les props. 2. Impl\u00e9menter le routing avec protection des routes. 3. Configurer Axios pour les appels API (baseURL + interceptors pour JWT). 4. Ajouter des tests avec React Testing Library. 5. Utiliser TailwindCSS pour le styling. 6. Impl\u00e9menter les filtres avec des query params (URLSearchParams)."
  },
  "auth": "JWT avec python-jose + passlib bcrypt (backend), stockage dans localStorage (frontend)",
  "cache": "none",
  "message_broker": "none",
  "container": {
    "docker": {
      "backend": {
        "image": "python:3.10-slim",
        "ports": [
          "8000:8000"
        ],
        "dependencies": [
          "FastAPI",
          "SQLAlchemy",
          "python-jose",
          "passlib"
        ]
      },
      "frontend": {
        "image": "node:18-alpine",
        "ports": [
          "3000:3000"
        ],
        "dependencies": [
          "React",
          "TypeScript",
          "Vite",
          "TailwindCSS"
        ]
      },
      "database": {
        "image": "postgres:15-alpine",
        "ports": [
          "5432:5432"
        ],
        "environment": {
          "POSTGRES_USER": "todo_user",
          "POSTGRES_PASSWORD": "todo_password",
          "POSTGRES_DB": "todo_db"
        }
      }
    },
    "docker_compose": {
      "version": "3.8",
      "services": [
        "backend",
        "frontend",
        "database"
      ],
      "networks": [
        "todo_network"
      ]
    }
  },
  "cloud": "D\u00e9ploiement local pour d\u00e9veloppement, cible future: Render ou Railway"
}