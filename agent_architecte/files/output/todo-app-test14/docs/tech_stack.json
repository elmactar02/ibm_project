{
  "database": {
    "technology": "PostgreSQL 15",
    "models": [
      {
        "name": "User",
        "fields": {
          "id": "UUID (primary key)",
          "email": "String (unique, index)",
          "hashed_password": "String",
          "created_at": "DateTime (default now)"
        }
      },
      {
        "name": "Task",
        "fields": {
          "id": "UUID (primary key)",
          "title": "String (max 255)",
          "description": "Text (nullable)",
          "status": "Enum('todo', 'in_progress', 'done')",
          "priority": "Enum('low', 'medium', 'high')",
          "due_date": "Date (nullable)",
          "user_id": "UUID (foreign key to User)",
          "created_at": "DateTime (default now)",
          "updated_at": "DateTime (default now, on update)"
        },
        "relations": [
          "Many-to-One avec User (user_id)"
        ]
      }
    ],
    "indexes": [
      "CREATE INDEX idx_task_user_status ON task(user_id, status)",
      "CREATE INDEX idx_task_user_priority ON task(user_id, priority)"
    ],
    "instructions": "1. Cr\u00e9er les tables avec SQLAlchemy ORM 2. Impl\u00e9menter les migrations avec Alembic 3. Configurer la connexion PostgreSQL avec asyncpg 4. Ajouter les indexes pour optimiser les filtres"
  },
  "backend": {
    "technology": "FastAPI (Python 3.10)",
    "endpoints": [
      {
        "method": "POST",
        "path": "/auth/register",
        "description": "Inscription utilisateur",
        "auth_required": false,
        "request_body": {
          "email": "string",
          "password": "string"
        },
        "response": {
          "access_token": "string",
          "token_type": "string"
        }
      },
      {
        "method": "POST",
        "path": "/auth/login",
        "description": "Connexion utilisateur",
        "auth_required": false,
        "request_body": {
          "username": "string",
          "password": "string"
        },
        "response": {
          "access_token": "string",
          "token_type": "string"
        }
      },
      {
        "method": "GET",
        "path": "/tasks",
        "description": "Liste des t\u00e2ches avec filtres",
        "auth_required": true,
        "query_params": {
          "status": "optional enum",
          "priority": "optional enum"
        },
        "response": {
          "tasks": "array of Task"
        }
      },
      {
        "method": "POST",
        "path": "/tasks",
        "description": "Cr\u00e9er une t\u00e2che",
        "auth_required": true,
        "request_body": {
          "title": "string",
          "description": "optional string",
          "status": "optional enum",
          "priority": "optional enum",
          "due_date": "optional date"
        },
        "response": {
          "task": "Task"
        }
      },
      {
        "method": "PUT",
        "path": "/tasks/{task_id}",
        "description": "Modifier une t\u00e2che",
        "auth_required": true,
        "request_body": {
          "title": "optional string",
          "description": "optional string",
          "status": "optional enum",
          "priority": "optional enum",
          "due_date": "optional date"
        },
        "response": {
          "task": "Task"
        }
      },
      {
        "method": "DELETE",
        "path": "/tasks/{task_id}",
        "description": "Supprimer une t\u00e2che",
        "auth_required": true,
        "response": {
          "detail": "string"
        }
      }
    ],
    "auth": {
      "approach": "JWT avec python-jose (jose.jwt) + hachage bcrypt (passlib)",
      "token_expiration": "30 minutes",
      "secret_key": "\u00c0 g\u00e9n\u00e9rer via secrets.token_urlsafe(32)",
      "algorithm": "HS256"
    },
    "structure": {
      "routers": [
        "auth.py",
        "tasks.py"
      ],
      "services": [
        "auth_service.py",
        "tasks_service.py"
      ],
      "models": [
        "schemas.py (Pydantic)",
        "models.py (SQLAlchemy)"
      ],
      "config": [
        "config.py (settings)",
        "database.py (session)"
      ]
    },
    "instructions": "1. Configurer FastAPI avec middleware CORS 2. Impl\u00e9menter les routers avec d\u00e9pendances d'authentification 3. Cr\u00e9er les services avec logique m\u00e9tier 4. Configurer la validation des donn\u00e9es avec Pydantic 5. Impl\u00e9menter les tests unitaires avec pytest 6. Ajouter la documentation Swagger/OpenAPI"
  },
  "frontend": {
    "technology": "React 18 + TypeScript + Vite",
    "components": [
      {
        "name": "AuthLayout",
        "description": "Layout pour pages d'authentification (login/register)"
      },
      {
        "name": "DashboardLayout",
        "description": "Layout principal avec sidebar et header"
      },
      {
        "name": "TaskList",
        "description": "Liste des t\u00e2ches avec filtres et pagination"
      },
      {
        "name": "TaskItem",
        "description": "Composant individuel de t\u00e2che avec actions (\u00e9diter/supprimer)"
      },
      {
        "name": "TaskForm",
        "description": "Formulaire de cr\u00e9ation/modification de t\u00e2che"
      },
      {
        "name": "AuthForm",
        "description": "Formulaire d'inscription/connexion"
      },
      {
        "name": "FilterBar",
        "description": "Barre de filtres par statut et priorit\u00e9"
      }
    ],
    "pages": [
      {
        "name": "LoginPage",
        "path": "/login",
        "description": "Page de connexion"
      },
      {
        "name": "RegisterPage",
        "path": "/register",
        "description": "Page d'inscription"
      },
      {
        "name": "DashboardPage",
        "path": "/dashboard",
        "description": "Page principale avec liste des t\u00e2ches"
      },
      {
        "name": "TaskCreatePage",
        "path": "/tasks/new",
        "description": "Page de cr\u00e9ation de t\u00e2che"
      },
      {
        "name": "TaskEditPage",
        "path": "/tasks/:id/edit",
        "description": "Page d'\u00e9dition de t\u00e2che"
      }
    ],
    "state_management": "React Context + useReducer pour l'authentification, Zustand pour les t\u00e2ches",
    "styling": "Tailwind CSS + DaisyUI pour les composants",
    "routing": "React Router v6",
    "api_client": "Axios avec interceptors pour JWT",
    "instructions": "1. Configurer Vite avec TypeScript et Tailwind 2. Cr\u00e9er les layouts et composants r\u00e9utilisables 3. Impl\u00e9menter le routing avec protection des routes 4. Configurer le state management pour l'auth et les t\u00e2ches 5. Cr\u00e9er les formulaires avec validation (React Hook Form + Zod) 6. Impl\u00e9menter les appels API avec Axios 7. Ajouter les tests avec Jest et React Testing Library 8. Configurer les builds de production avec optimisation"
  },
  "auth": "JWT avec stockage dans httpOnly cookies (backend) et gestion via React Context (frontend)",
  "cache": "none (\u00e0 consid\u00e9rer pour les t\u00e2ches fr\u00e9quemment acc\u00e9d\u00e9es)",
  "message_broker": "none",
  "container": {
    "docker": {
      "backend": {
        "image": "python:3.10-slim",
        "ports": [
          "8000:8000"
        ],
        "volumes": [
          ".:/app"
        ],
        "command": "uvicorn main:app --host 0.0.0.0 --port 8000 --reload"
      },
      "frontend": {
        "image": "node:18-alpine",
        "ports": [
          "3000:3000"
        ],
        "volumes": [
          ".:/app"
        ],
        "command": "npm run dev"
      },
      "database": {
        "image": "postgres:15",
        "ports": [
          "5432:5432"
        ],
        "environment": {
          "POSTGRES_USER": "todo_user",
          "POSTGRES_PASSWORD": "todo_password",
          "POSTGRES_DB": "todo_db"
        },
        "volumes": [
          "postgres_data:/var/lib/postgresql/data"
        ]
      }
    },
    "docker_compose": {
      "version": "3.8",
      "services": {
        "backend": {
          "build": "./backend",
          "ports": [
            "8000:8000"
          ],
          "depends_on": [
            "db"
          ]
        },
        "frontend": {
          "build": "./frontend",
          "ports": [
            "3000:3000"
          ],
          "depends_on": [
            "backend"
          ]
        },
        "db": {
          "image": "postgres:15",
          "environment": {
            "POSTGRES_USER": "todo_user",
            "POSTGRES_PASSWORD": "todo_password",
            "POSTGRES_DB": "todo_db"
          },
          "volumes": [
            "postgres_data:/var/lib/postgresql/data"
          ]
        }
      },
      "volumes": {
        "postgres_data": null
      }
    }
  },
  "cloud": "D\u00e9ploiement local pour d\u00e9veloppement, cible production: Render ou Railway pour backend, Vercel pour frontend"
}