{
  "database": {
    "technology": "PostgreSQL 15",
    "models": [
      {
        "name": "User",
        "fields": {
          "id": "Integer (Primary Key)",
          "email": "String (Unique, 255 chars)",
          "hashed_password": "String (255 chars)",
          "full_name": "String (100 chars, nullable)",
          "created_at": "DateTime (default now)"
        },
        "relations": [
          "One-to-Many avec Task"
        ]
      },
      {
        "name": "Task",
        "fields": {
          "id": "Integer (Primary Key)",
          "title": "String (100 chars)",
          "description": "Text (nullable)",
          "status": "Enum('todo', 'in_progress', 'done')",
          "priority": "Enum('low', 'medium', 'high')",
          "due_date": "Date (nullable)",
          "created_at": "DateTime (default now)",
          "updated_at": "DateTime (default now, on update)",
          "user_id": "Integer (Foreign Key)"
        },
        "relations": [
          "Many-to-One avec User"
        ]
      }
    ],
    "indexes": [
      "CREATE INDEX idx_task_user_id ON task(user_id)",
      "CREATE INDEX idx_task_status ON task(status)",
      "CREATE INDEX idx_task_priority ON task(priority)"
    ],
    "instructions": "Oumeyma: Cr\u00e9e les mod\u00e8les SQLAlchemy avec les champs exacts ci-dessus. Utilise Alembic pour les migrations. Impl\u00e9mente les indexes pour optimiser les filtres. Ajoute une contrainte CHECK pour emp\u00eacher les dates de cr\u00e9ation post\u00e9rieures \u00e0 la date de mise \u00e0 jour."
  },
  "backend": {
    "technology": "FastAPI (Python 3.10)",
    "endpoints": [
      {
        "path": "/auth/register",
        "method": "POST",
        "description": "Inscription d'un nouvel utilisateur",
        "auth_required": false,
        "request_body": {
          "email": "string (format email)",
          "password": "string (min 8 chars)",
          "full_name": "string (optional)"
        },
        "response": {
          "access_token": "string (JWT)",
          "token_type": "string (bearer)"
        }
      },
      {
        "path": "/auth/login",
        "method": "POST",
        "description": "Connexion d'un utilisateur existant",
        "auth_required": false,
        "request_body": {
          "email": "string (format email)",
          "password": "string"
        },
        "response": {
          "access_token": "string (JWT)",
          "token_type": "string (bearer)"
        }
      },
      {
        "path": "/tasks",
        "method": "GET",
        "description": "Liste des t\u00e2ches avec filtres",
        "auth_required": true,
        "query_params": {
          "status": "string (optional, enum: todo|in_progress|done)",
          "priority": "string (optional, enum: low|medium|high)",
          "limit": "integer (optional, default 10)",
          "offset": "integer (optional, default 0)"
        },
        "response": {
          "tasks": "array of Task objects",
          "total": "integer"
        }
      },
      {
        "path": "/tasks",
        "method": "POST",
        "description": "Cr\u00e9ation d'une nouvelle t\u00e2che",
        "auth_required": true,
        "request_body": {
          "title": "string (max 100 chars)",
          "description": "string (optional)",
          "status": "string (optional, default 'todo')",
          "priority": "string (optional, default 'medium')",
          "due_date": "string (optional, format YYYY-MM-DD)"
        },
        "response": "Task object"
      },
      {
        "path": "/tasks/{task_id}",
        "method": "GET",
        "description": "R\u00e9cup\u00e9ration d'une t\u00e2che sp\u00e9cifique",
        "auth_required": true,
        "response": "Task object"
      },
      {
        "path": "/tasks/{task_id}",
        "method": "PUT",
        "description": "Mise \u00e0 jour d'une t\u00e2che",
        "auth_required": true,
        "request_body": {
          "title": "string (optional)",
          "description": "string (optional)",
          "status": "string (optional)",
          "priority": "string (optional)",
          "due_date": "string (optional)"
        },
        "response": "Task object"
      },
      {
        "path": "/tasks/{task_id}",
        "method": "DELETE",
        "description": "Suppression d'une t\u00e2che",
        "auth_required": true,
        "response": {
          "detail": "string (Task deleted successfully)"
        }
      }
    ],
    "auth": {
      "approach": "JWT avec python-jose (JWS) et passlib (bcrypt)",
      "token_expiration": "30 minutes",
      "refresh_tokens": false,
      "security_schemes": {
        "OAuth2PasswordBearer": {
          "tokenUrl": "/auth/login",
          "scopes": {}
        }
      }
    },
    "structure": {
      "routers": [
        "auth.py (routes /auth)",
        "tasks.py (routes /tasks)"
      ],
      "services": [
        "users.py (logique m\u00e9tier utilisateurs)",
        "tasks.py (logique m\u00e9tier t\u00e2ches)"
      ],
      "models": [
        "user.py (mod\u00e8le User)",
        "task.py (mod\u00e8le Task)"
      ],
      "database": [
        "session.py (gestion des sessions SQLAlchemy)",
        "base.py (d\u00e9claration Base)"
      ],
      "utils": [
        "jwt.py (g\u00e9n\u00e9ration/validation JWT)",
        "security.py (hashage des mots de passe)"
      ],
      "config": [
        "settings.py (variables d'environnement)"
      ]
    },
    "instructions": "Akram: Impl\u00e9mente les endpoints FastAPI avec les sp\u00e9cifications ci-dessus. Utilise SQLAlchemy pour les interactions avec la base de donn\u00e9es. Impl\u00e9mente l'authentification JWT avec les d\u00e9pendances python-jose et passlib. Structure le projet selon les dossiers mentionn\u00e9s. Ajoute des tests unitaires pour chaque endpoint (pytest)."
  },
  "frontend": {
    "technology": "React 18 + TypeScript + Vite",
    "pages": [
      {
        "name": "LoginPage",
        "path": "/login",
        "components": [
          "LoginForm",
          "AuthLayout"
        ]
      },
      {
        "name": "RegisterPage",
        "path": "/register",
        "components": [
          "RegisterForm",
          "AuthLayout"
        ]
      },
      {
        "name": "DashboardPage",
        "path": "/",
        "components": [
          "DashboardLayout",
          "TaskList",
          "TaskFilters",
          "TaskForm",
          "TaskItem",
          "Navbar"
        ],
        "protected": true
      }
    ],
    "components": [
      {
        "name": "AuthLayout",
        "description": "Layout commun pour les pages d'authentification avec logo et fond"
      },
      {
        "name": "DashboardLayout",
        "description": "Layout principal avec barre de navigation et espace de travail"
      },
      {
        "name": "TaskList",
        "description": "Liste des t\u00e2ches avec pagination et filtres appliqu\u00e9s"
      },
      {
        "name": "TaskFilters",
        "description": "Composant de filtres par statut et priorit\u00e9 avec boutons radio"
      },
      {
        "name": "TaskForm",
        "description": "Formulaire modal pour cr\u00e9ation/modification de t\u00e2che"
      },
      {
        "name": "TaskItem",
        "description": "Composant individuel de t\u00e2che avec actions (\u00e9diter/supprimer)"
      },
      {
        "name": "Navbar",
        "description": "Barre de navigation avec logo et bouton de d\u00e9connexion"
      }
    ],
    "routing": {
      "library": "React Router v6",
      "routes": [
        {
          "path": "/login",
          "element": "<LoginPage />"
        },
        {
          "path": "/register",
          "element": "<RegisterPage />"
        },
        {
          "path": "/",
          "element": "<DashboardPage />",
          "protected": true
        }
      ]
    },
    "state_management": {
      "approach": "React Context + useReducer",
      "contexts": [
        {
          "name": "AuthContext",
          "purpose": "Gestion de l'\u00e9tat d'authentification (token, user)"
        },
        {
          "name": "TasksContext",
          "purpose": "Gestion de l'\u00e9tat des t\u00e2ches (liste, filtres, chargement)"
        }
      ]
    },
    "api_client": {
      "library": "Axios",
      "base_url": "/api",
      "interceptors": [
        {
          "type": "request",
          "action": "Ajouter le token JWT dans les headers Authorization"
        },
        {
          "type": "response",
          "action": "G\u00e9rer les erreurs 401 (d\u00e9connexion)"
        }
      ]
    },
    "styling": {
      "library": "Tailwind CSS",
      "theme": {
        "colors": {
          "primary": "#3B82F6",
          "secondary": "#10B981",
          "danger": "#EF4444"
        }
      }
    },
    "instructions": "Mactar: Cr\u00e9e les pages et composants React avec TypeScript. Impl\u00e9mente le routing avec React Router v6 et prot\u00e8ge les routes n\u00e9cessitant une authentification. Utilise React Context pour la gestion d'\u00e9tat. Impl\u00e9mente les formulaires avec validation (React Hook Form + Zod). Style les composants avec Tailwind CSS. Cr\u00e9e un client API Axios avec interceptors pour g\u00e9rer l'authentification. Ajoute des tests unitaires (Jest + React Testing Library) et des tests d'int\u00e9gration pour les parcours utilisateurs principaux."
  },
  "auth": "JWT avec python-jose (JWS) et passlib (bcrypt pour le hashage des mots de passe)",
  "cache": "none",
  "message_broker": "none",
  "container": {
    "docker": {
      "files": [
        "Dockerfile pour le backend (FastAPI)",
        "Dockerfile pour le frontend (React)",
        "docker-compose.yml pour orchestrer frontend, backend et PostgreSQL"
      ],
      "instructions": "DevOps: Cr\u00e9e un Dockerfile multi-stage pour le backend FastAPI avec Python 3.10. Cr\u00e9e un Dockerfile pour le frontend avec Nginx pour servir les fichiers statiques. Configure docker-compose.yml pour lancer les 3 services (frontend, backend, db) avec des volumes pour le d\u00e9veloppement. Ajoute un service pgAdmin optionnel pour la gestion de la base de donn\u00e9es."
    }
  },
  "cloud": "D\u00e9ploiement local pour le d\u00e9veloppement, cible AWS ECS ou Vercel pour la production"
}