{
  "database": {
    "technology": "PostgreSQL 15",
    "models": [
      {
        "name": "User",
        "fields": {
          "id": "UUID (primary key)",
          "email": "String (unique, index)",
          "hashed_password": "String",
          "created_at": "DateTime (default now)",
          "updated_at": "DateTime (default now)"
        }
      },
      {
        "name": "Task",
        "fields": {
          "id": "UUID (primary key)",
          "title": "String (max 255)",
          "description": "Text (nullable)",
          "status": "Enum('todo', 'in_progress', 'done')",
          "priority": "Enum('low', 'medium', 'high')",
          "due_date": "DateTime (nullable)",
          "user_id": "UUID (foreign key to User)",
          "created_at": "DateTime (default now)",
          "updated_at": "DateTime (default now)"
        },
        "relations": [
          "Many-to-One avec User (user_id)"
        ]
      }
    ],
    "indexes": [
      "CREATE INDEX idx_task_user_id ON task(user_id)",
      "CREATE INDEX idx_task_status ON task(status)",
      "CREATE INDEX idx_task_priority ON task(priority)"
    ]
  },
  "backend": {
    "framework": "FastAPI",
    "auth": "JWT avec python-jose et passlib (bcrypt pour hachage)",
    "routers": [
      {
        "path": "/auth",
        "endpoints": [
          {
            "method": "POST",
            "path": "/register",
            "description": "Inscription utilisateur"
          },
          {
            "method": "POST",
            "path": "/login",
            "description": "Connexion utilisateur (retourne JWT)"
          }
        ]
      },
      {
        "path": "/tasks",
        "endpoints": [
          {
            "method": "GET",
            "path": "/",
            "description": "Liste des t\u00e2ches avec filtres (status, priority)"
          },
          {
            "method": "POST",
            "path": "/",
            "description": "Cr\u00e9er une t\u00e2che"
          },
          {
            "method": "PUT",
            "path": "/{task_id}",
            "description": "Modifier une t\u00e2che"
          },
          {
            "method": "DELETE",
            "path": "/{task_id}",
            "description": "Supprimer une t\u00e2che"
          }
        ],
        "auth_required": true
      }
    ],
    "structure": {
      "directories": [
        "app/auth",
        "app/tasks",
        "app/models",
        "app/database"
      ],
      "files": [
        "main.py (point d'entr\u00e9e FastAPI)",
        "config.py (configuration JWT, DB)",
        "schemas.py (Pydantic models)",
        "dependencies.py (d\u00e9pendances FastAPI)"
      ]
    }
  },
  "frontend": {
    "framework": "React 18 + TypeScript",
    "libraries": [
      "React Router v6",
      "Axios",
      "TailwindCSS",
      "React Hook Form",
      "Zustand (state management)"
    ],
    "pages": [
      {
        "name": "Login",
        "path": "/login",
        "components": [
          "LoginForm",
          "AuthLayout"
        ]
      },
      {
        "name": "Register",
        "path": "/register",
        "components": [
          "RegisterForm",
          "AuthLayout"
        ]
      },
      {
        "name": "Dashboard",
        "path": "/",
        "components": [
          "TaskList",
          "TaskFilters",
          "TaskForm",
          "Navbar"
        ]
      }
    ],
    "components": [
      {
        "name": "TaskList",
        "description": "Affiche les t\u00e2ches avec filtres (status/priority), permet la suppression"
      },
      {
        "name": "TaskForm",
        "description": "Formulaire modal pour cr\u00e9er/modifier une t\u00e2che"
      },
      {
        "name": "TaskFilters",
        "description": "Filtres par statut et priorit\u00e9 avec boutons radio"
      }
    ],
    "routing": {
      "public": [
        "/login",
        "/register"
      ],
      "private": [
        "/",
        "/tasks/*"
      ],
      "auth_guard": "HOC ou custom hook pour prot\u00e9ger les routes priv\u00e9es"
    }
  },
  "auth": "JWT avec python-jose (algorithme HS256), dur\u00e9e de validit\u00e9 15 minutes (refresh token non impl\u00e9ment\u00e9 dans cette version)",
  "cache": "None (peut \u00eatre ajout\u00e9 ult\u00e9rieurement avec Redis pour les t\u00e2ches fr\u00e9quentes)",
  "message_broker": "None",
  "container": {
    "docker": {
      "files": [
        "Dockerfile (backend)",
        "Dockerfile (frontend)",
        "docker-compose.yml"
      ],
      "services": [
        {
          "name": "backend",
          "port": "8000",
          "environment": [
            "DATABASE_URL",
            "SECRET_KEY",
            "JWT_ALGORITHM",
            "ACCESS_TOKEN_EXPIRE_MINUTES"
          ]
        },
        {
          "name": "frontend",
          "port": "3000",
          "environment": [
            "REACT_APP_API_URL"
          ]
        },
        {
          "name": "db",
          "port": "5432",
          "volumes": [
            "postgres_data:/var/lib/postgresql/data"
          ]
        }
      ]
    }
  },
  "cloud": "D\u00e9ploiement local pour d\u00e9veloppement, cible GitHub Pages (frontend) + Render/Heroku (backend) pour production"
}