      "sql": "CREATE TABLE IF NOT EXISTS tasks (id INTEGER PRIMARY KEY AUTOINCREMENT, title TEXT NOT NULL, description TEXT, status TEXT NOT NULL CHECK(status IN ('todo', 'in_progress', 'done')), priority TEXT NOT NULL CHECK(priority IN ('low', 'medium', 'high')), created_at TEXT NOT NULL DEFAULT (datetime('now')), updated_at TEXT NOT NULL DEFAULT (datetime('now')) ON CONFLICT REPLACE, user_id INTEGER NOT NULL, deleted_at TEXT DEFAULT NULL, FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE)",
