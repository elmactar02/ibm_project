{
  "database": {
    "technology": "PostgreSQL 15",
    "models": [
      {
        "name": "User",
        "fields": {
          "id": "Integer (Primary Key)",
          "email": "String (Unique, 255 chars)",
          "hashed_password": "String (255 chars)",
          "created_at": "DateTime (default now)"
        }
      },
      {
        "name": "Task",
        "fields": {
          "id": "Integer (Primary Key)",
          "title": "String (255 chars)",
          "description": "Text (nullable)",
          "status": "Enum('todo', 'in_progress', 'done')",
          "priority": "Enum('low', 'medium', 'high')",
          "created_at": "DateTime (default now)",
          "updated_at": "DateTime (default now, on update)",
          "user_id": "Integer (Foreign Key -> User.id)"
        },
        "relations": [
          "Many-to-One avec User"
        ]
      }
    ],
    "indexes": [
      "CREATE INDEX idx_task_user_id ON task(user_id)",
      "CREATE INDEX idx_task_status ON task(status)",
      "CREATE INDEX idx_task_priority ON task(priority)"
    ]
  },
  "backend": {
    "framework": "FastAPI",
    "auth": {
      "jwt": {
        "secret_key": "Variable d'environnement (JWT_SECRET)",
        "algorithm": "HS256",
        "expire_minutes": 30
      },
      "password_hashing": "Passlib avec bcrypt"
    },
    "routers": [
      {
        "name": "auth",
        "endpoints": [
          {
            "path": "/register",
            "method": "POST",
            "description": "Inscription utilisateur"
          },
          {
            "path": "/login",
            "method": "POST",
            "description": "Connexion avec JWT"
          },
          {
            "path": "/me",
            "method": "GET",
            "description": "Infos utilisateur courant (auth required)"
          }
        ]
      },
      {
        "name": "tasks",
        "endpoints": [
          {
            "path": "/tasks",
            "method": "GET",
            "description": "Liste des t\u00e2ches avec filtres (status, priority)"
          },
          {
            "path": "/tasks",
            "method": "POST",
            "description": "Cr\u00e9er une t\u00e2che (auth required)"
          },
          {
            "path": "/tasks/{id}",
            "method": "GET",
            "description": "D\u00e9tails d'une t\u00e2che (auth required)"
          },
          {
            "path": "/tasks/{id}",
            "method": "PUT",
            "description": "Modifier une t\u00e2che (auth required)"
          },
          {
            "path": "/tasks/{id}",
            "method": "DELETE",
            "description": "Supprimer une t\u00e2che (auth required)"
          }
        ]
      }
    ],
    "dependencies": [
      "SQLAlchemy",
      "python-jose[cryptography]",
      "passlib[bcrypt]",
      "python-multipart",
      "uvicorn"
    ]
  },
  "frontend": {
    "framework": "React 18 + TypeScript",
    "libraries": [
      "React Router v6",
      "Axios",
      "TailwindCSS",
      "React Hook Form",
      "Zod"
    ],
    "pages": [
      {
        "name": "Login",
        "path": "/login",
        "components": [
          "LoginForm",
          "AuthLayout"
        ]
      },
      {
        "name": "Register",
        "path": "/register",
        "components": [
          "RegisterForm",
          "AuthLayout"
        ]
      },
      {
        "name": "Dashboard",
        "path": "/",
        "components": [
          "TaskList",
          "TaskFilters",
          "TaskForm",
          "Navbar"
        ]
      },
      {
        "name": "TaskDetail",
        "path": "/tasks/:id",
        "components": [
          "TaskDetailCard"
        ]
      }
    ],
    "state_management": "React Context pour l'auth + useState pour les t\u00e2ches",
    "api_client": {
      "base_url": "http://localhost:8000",
      "endpoints": {
        "auth": {
          "login": "/login",
          "register": "/register",
          "me": "/me"
        },
        "tasks": {
          "list": "/tasks",
          "create": "/tasks",
          "detail": "/tasks/{id}",
          "update": "/tasks/{id}",
          "delete": "/tasks/{id}"
        }
      }
    }
  },
  "auth": "JWT avec python-jose (HS256) + Passlib bcrypt pour le hachage des mots de passe",
  "cache": "None (pas de cache pour cette version)",
  "message_broker": "None",
  "container": {
    "docker": {
      "frontend": {
        "image": "node:18-alpine",
        "port": 3000,
        "build": "npm install && npm run build"
      },
      "backend": {
        "image": "python:3.10-slim",
        "port": 8000,
        "build": "pip install -r requirements.txt && uvicorn main:app --host 0.0.0.0 --port 8000"
      },
      "database": {
        "image": "postgres:15-alpine",
        "port": 5432,
        "environment": {
          "POSTGRES_USER": "todo_user",
          "POSTGRES_PASSWORD": "todo_password",
          "POSTGRES_DB": "todo_db"
        }
      }
    },
    "docker_compose": {
      "version": "3.8",
      "services": [
        "frontend",
        "backend",
        "database"
      ],
      "networks": [
        "todo_network"
      ]
    }
  },
  "cloud": "D\u00e9ploiement local pour le d\u00e9veloppement, cible GitHub Pages pour le frontend et un VPS pour le backend (via CI/CD)"
}