{
  "project": {
    "name": "todo-app-test20",
    "description": "Construire une application de gestion de tâches (To-Do list). Fonctionnalités: inscription et connex",
    "complexity": "medium"
  },
  "modules": [],
  "user_journeys": [],
  "entities": [],
  "api_endpoints": [],
  "tech_stack": {
    "database": {
      "technology": "PostgreSQL 15",
      "models": [
        {
          "name": "User",
          "fields": {
            "id": "UUID (primary key)",
            "email": "String (unique, index)",
            "hashed_password": "String",
            "created_at": "DateTime (default now)"
          }
        },
        {
          "name": "Task",
          "fields": {
            "id": "UUID (primary key)",
            "title": "String (max 255)",
            "description": "Text (nullable)",
            "status": "Enum('todo', 'in_progress', 'done')",
            "priority": "Enum('low', 'medium', 'high')",
            "due_date": "Date (nullable)",
            "user_id": "UUID (foreign key to User)",
            "created_at": "DateTime (default now)",
            "updated_at": "DateTime (default now, on update)"
          },
          "relations": [
            "Many-to-One avec User (user_id)"
          ]
        }
      ],
      "indexes": [
        "CREATE INDEX idx_task_user_id ON task(user_id)",
        "CREATE INDEX idx_task_status ON task(status)",
        "CREATE INDEX idx_task_priority ON task(priority)"
      ]
    },
    "backend": {
      "framework": "FastAPI",
      "auth": {
        "approach": "JWT avec python-jose (JWS) + passlib (bcrypt)",
        "token_expiry": "15 minutes (access token), 7 jours (refresh token)",
        "endpoints": [
          {
            "path": "/auth/register",
            "method": "POST",
            "description": "Inscription utilisateur"
          },
          {
            "path": "/auth/login",
            "method": "POST",
            "description": "Connexion avec email/mot de passe"
          },
          {
            "path": "/auth/refresh",
            "method": "POST",
            "description": "Rafraîchissement du token"
          }
        ]
      },
      "tasks_endpoints": [
        {
          "path": "/tasks",
          "method": "GET",
          "description": "Liste des tâches avec filtres (status, priority)",
          "auth_required": true
        },
        {
          "path": "/tasks",
          "method": "POST",
          "description": "Créer une tâche",
          "auth_required": true
        },
        {
          "path": "/tasks/{task_id}",
          "method": "GET",
          "description": "Récupérer une tâche",
          "auth_required": true
        },
        {
          "path": "/tasks/{task_id}",
          "method": "PUT",
          "description": "Mettre à jour une tâche",
          "auth_required": true
        },
        {
          "path": "/tasks/{task_id}",
          "method": "DELETE",
          "description": "Supprimer une tâche",
          "auth_required": true
        }
      ],
      "structure": {
        "routers": [
          "auth.py",
          "tasks.py"
        ],
        "services": [
          "auth_service.py"
        ],
        "models": [
          "user.py",
          "task.py"
        ],
        "database": [
          "database.py (session management)"
        ]
      }
    },
    "frontend": {
      "framework": "React 18 + TypeScript",
      "state_management": "React Context + useReducer",
      "routing": "React Router v6",
      "ui_library": "Material-UI v5",
      "components": [
        {
          "name": "AuthLayout",
          "description": "Layout pour pages d'authentification (login/register)"
        },
        {
          "name": "DashboardLayout",
          "description": "Layout principal avec sidebar de navigation"
        },
        {
          "name": "TaskList",
          "description": "Liste des tâches avec filtres et pagination"
        },
        {
          "name": "TaskForm",
          "description": "Formulaire de création/modification de tâche"
        },
        {
          "name": "TaskCard",
          "description": "Carte individuelle pour une tâche"
        },
        {
          "name": "AuthProvider",
          "description": "Contexte d'authentification (stockage JWT)"
        }
      ],
      "pages": [
        {
          "name": "LoginPage",
          "path": "/login"
        },
        {
          "name": "RegisterPage",
          "path": "/register"
        },
        {
          "name": "DashboardPage",
          "path": "/",
          "protected": true
        },
        {
          "name": "TaskDetailPage",
          "path": "/tasks/:id",
          "protected": true
        }
      ],
      "api_client": "Axios avec interceptors pour gestion des tokens"
    },
    "auth": "JWT avec python-jose + passlib bcrypt (access token 15min, refresh token 7j)",
    "cache": "None (Redis envisagé pour scalabilité future)",
    "message_broker": "None",
    "container": {
      "docker": {
        "files": [
          "Dockerfile pour backend",
          "Dockerfile pour frontend",
          "docker-compose.yml"
        ],
        "services": {
          "backend": {
            "port": 8000,
            "depends_on": [
              "db"
            ]
          },
          "frontend": {
            "port": 3000,
            "depends_on": [
              "backend"
            ]
          },
          "db": {
            "image": "postgres:15",
            "ports": [
              "5432:5432"
            ],
            "volumes": [
              "postgres_data:/var/lib/postgresql/data"
            ]
          }
        }
      },
      "ci_cd": {
        "github_actions": {
          "workflows": [
            {
              "name": "test-and-build",
              "triggers": [
                "push",
                "pull_request"
              ],
              "jobs": {
                "backend_tests": {
                  "runs-on": "ubuntu-latest",
                  "steps": [
                    "checkout",
                    "setup python",
                    "install deps",
                    "run pytest"
                  ]
                },
                "frontend_tests": {
                  "runs-on": "ubuntu-latest",
                  "steps": [
                    "checkout",
                    "setup node",
                    "install deps",
                    "run tests"
                  ]
                },
                "build_docker": {
                  "runs-on": "ubuntu-latest",
                  "steps": [
                    "checkout",
                    "login to docker hub",
                    "build and push images"
                  ]
                }
              }
            }
          ]
        }
      }
    },
    "cloud": "Déploiement local pour développement, cible AWS ECS pour production"
  },
  "dev_instructions": {
    "database": "",
    "backend": "",
    "frontend": ""
  },
  "constraints": [],
  "estimated_files": {
    "database": 3,
    "backend": 8,
    "frontend": 10
  }
}