  "constraints": [
    "Le token JWT doit expirer après 30 minutes d'inactivité",
    "Les mots de passe doivent être hachés avec bcrypt (coût 12)",
    "Les filtres de tâches doivent être implémentés côté serveur",
    "L'application doit être responsive (mobile, tablette, desktop)",
    "Le pipeline CI/CD doit inclure des tests avant déploiement",
    "Les indexes PostgreSQL doivent être créés pour les champs fréquemment filtrés"
  ],
  "estimated_files": {
    "database": 3,
    "backend": 15,
    "frontend": 25
  }
