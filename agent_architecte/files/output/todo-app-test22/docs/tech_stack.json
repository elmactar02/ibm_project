{
  "database": {
    "technology": "PostgreSQL 15",
    "models": [
      {
        "name": "User",
        "fields": {
          "id": "Integer (Primary Key)",
          "email": "String (Unique, 255 chars)",
          "hashed_password": "String (255 chars)",
          "full_name": "String (100 chars, nullable)",
          "is_active": "Boolean (default=True)",
          "created_at": "DateTime (default=now)"
        },
        "relations": [
          "One-to-Many avec Task"
        ]
      },
      {
        "name": "Task",
        "fields": {
          "id": "Integer (Primary Key)",
          "title": "String (100 chars)",
          "description": "Text (nullable)",
          "status": "Enum (todo, in_progress, done)",
          "priority": "Enum (low, medium, high)",
          "due_date": "Date (nullable)",
          "created_at": "DateTime (default=now)",
          "updated_at": "DateTime (default=now, onupdate=now)",
          "user_id": "Integer (Foreign Key: User.id)"
        },
        "relations": [
          "Many-to-One avec User"
        ]
      }
    ],
    "indexes": [
      "CREATE INDEX idx_task_user_id ON task(user_id)",
      "CREATE INDEX idx_task_status ON task(status)",
      "CREATE INDEX idx_task_priority ON task(priority)"
    ],
    "instructions": "Utiliser SQLAlchemy 2.0 avec Alembic pour les migrations. Cr\u00e9er un fichier models.py avec les deux mod\u00e8les ci-dessus. Configurer la relation bidirectionnelle entre User et Task. Impl\u00e9menter les indexes pour optimiser les filtres."
  },
  "backend": {
    "technology": "FastAPI + Python 3.10",
    "endpoints": [
      {
        "path": "/auth/register",
        "method": "POST",
        "description": "Inscription d'un nouvel utilisateur",
        "auth_required": false,
        "request_body": {
          "email": "string",
          "password": "string",
          "full_name": "string (optional)"
        },
        "response": {
          "id": "integer",
          "email": "string",
          "full_name": "string"
        }
      },
      {
        "path": "/auth/login",
        "method": "POST",
        "description": "Connexion avec JWT",
        "auth_required": false,
        "request_body": {
          "username": "string (email)",
          "password": "string"
        },
        "response": {
          "access_token": "string",
          "token_type": "string"
        }
      },
      {
        "path": "/tasks",
        "method": "GET",
        "description": "Liste des t\u00e2ches avec filtres",
        "auth_required": true,
        "query_params": {
          "status": "string (optional, enum: todo,in_progress,done)",
          "priority": "string (optional, enum: low,medium,high)",
          "limit": "integer (optional, default=100)",
          "offset": "integer (optional, default=0)"
        },
        "response": {
          "items": [
            {
              "id": "integer",
              "title": "string",
              "status": "string",
              "priority": "string",
              "due_date": "string (date)"
            }
          ],
          "total": "integer"
        }
      },
      {
        "path": "/tasks",
        "method": "POST",
        "description": "Cr\u00e9ation d'une t\u00e2che",
        "auth_required": true,
        "request_body": {
          "title": "string",
          "description": "string (optional)",
          "status": "string (optional, enum, default=todo)",
          "priority": "string (optional, enum, default=medium)",
          "due_date": "string (date, optional)"
        },
        "response": {
          "id": "integer",
          "title": "string",
          "status": "string"
        }
      },
      {
        "path": "/tasks/{task_id}",
        "method": "GET",
        "description": "D\u00e9tails d'une t\u00e2che",
        "auth_required": true,
        "path_params": {
          "task_id": "integer"
        },
        "response": {
          "id": "integer",
          "title": "string",
          "description": "string",
          "status": "string",
          "priority": "string",
          "due_date": "string (date)",
          "created_at": "string (datetime)",
          "updated_at": "string (datetime)"
        }
      },
      {
        "path": "/tasks/{task_id}",
        "method": "PUT",
        "description": "Mise \u00e0 jour d'une t\u00e2che",
        "auth_required": true,
        "path_params": {
          "task_id": "integer"
        },
        "request_body": {
          "title": "string (optional)",
          "description": "string (optional)",
          "status": "string (optional, enum)",
          "priority": "string (optional, enum)",
          "due_date": "string (date, optional)"
        },
        "response": {
          "id": "integer",
          "title": "string",
          "status": "string"
        }
      },
      {
        "path": "/tasks/{task_id}",
        "method": "DELETE",
        "description": "Suppression d'une t\u00e2che",
        "auth_required": true,
        "path_params": {
          "task_id": "integer"
        },
        "response": {
          "detail": "string (success message)"
        }
      }
    ],
    "auth": {
      "approach": "JWT avec python-jose + passlib (bcrypt)",
      "token_expiration": "30 minutes",
      "refresh_token": false,
      "security_scheme": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "structure": {
      "routers": [
        "auth.py (routes /auth)",
        "tasks.py (routes /tasks)"
      ],
      "services": [
        "users.py (logique utilisateurs)",
        "tasks.py (logique t\u00e2ches)",
        "auth.py (logique JWT)"
      ],
      "models": "models.py (SQLAlchemy)",
      "database": "database.py (session et engine)",
      "config": "config.py (Pydantic settings)"
    },
    "instructions": "1. Cr\u00e9er un projet FastAPI avec la structure ci-dessus. 2. Impl\u00e9menter les endpoints list\u00e9s avec validation Pydantic. 3. Configurer l'authentification JWT avec d\u00e9pendance FastAPI pour les routes prot\u00e9g\u00e9es. 4. Utiliser SQLAlchemy pour les op\u00e9rations CRUD. 5. Ajouter des tests unitaires avec pytest pour chaque endpoint. 6. Configurer les CORS pour le frontend."
  },
  "frontend": {
    "technology": "React 18 + TypeScript + Vite",
    "pages": [
      {
        "name": "LoginPage",
        "path": "/login",
        "components": [
          "LoginForm",
          "AuthLayout"
        ],
        "description": "Page de connexion avec formulaire email/mot de passe"
      },
      {
        "name": "RegisterPage",
        "path": "/register",
        "components": [
          "RegisterForm",
          "AuthLayout"
        ],
        "description": "Page d'inscription avec formulaire"
      },
      {
        "name": "DashboardPage",
        "path": "/",
        "components": [
          "TaskList",
          "TaskFilters",
          "DashboardLayout",
          "TaskModal"
        ],
        "description": "Tableau de bord principal avec liste de t\u00e2ches et filtres"
      }
    ],
    "components": [
      {
        "name": "TaskList",
        "props": {
          "tasks": "Task[]",
          "onTaskUpdate": "function",
          "onTaskDelete": "function"
        },
        "description": "Affiche la liste des t\u00e2ches avec pagination"
      },
      {
        "name": "TaskFilters",
        "props": {
          "filters": "object",
          "onFilterChange": "function"
        },
        "description": "Composant de filtres par statut et priorit\u00e9"
      },
      {
        "name": "TaskModal",
        "props": {
          "task": "Task (optional)",
          "isOpen": "boolean",
          "onClose": "function",
          "onSubmit": "function"
        },
        "description": "Modal pour cr\u00e9er/modifier une t\u00e2che"
      },
      {
        "name": "AuthLayout",
        "description": "Layout pour les pages d'authentification"
      },
      {
        "name": "DashboardLayout",
        "description": "Layout pour le tableau de bord avec header et sidebar"
      }
    ],
    "routing": {
      "library": "React Router v6",
      "routes": [
        {
          "path": "/login",
          "element": "<LoginPage />",
          "protected": false
        },
        {
          "path": "/register",
          "element": "<RegisterPage />",
          "protected": false
        },
        {
          "path": "/",
          "element": "<DashboardPage />",
          "protected": true
        }
      ]
    },
    "state_management": {
      "auth": "React Context + useReducer",
      "tasks": "React Query pour le caching et les requ\u00eates API"
    },
    "styling": {
      "library": "Tailwind CSS",
      "theme": "Syst\u00e8me de design simple avec couleurs pour les priorit\u00e9s (low=green, medium=blue, high=red)"
    },
    "instructions": "1. Cr\u00e9er une application React avec Vite et TypeScript. 2. Configurer React Router pour la navigation. 3. Impl\u00e9menter les pages et composants list\u00e9s. 4. Configurer React Query pour les appels API avec gestion du cache. 5. Cr\u00e9er un contexte d'authentification pour g\u00e9rer le JWT. 6. Impl\u00e9menter les formulaires avec validation (React Hook Form + Zod). 7. Styliser avec Tailwind CSS. 8. Ajouter des tests avec Vitest et React Testing Library."
  },
  "auth": "JWT avec python-jose + passlib (bcrypt pour le hachage)",
  "cache": "none",
  "message_broker": "none",
  "container": {
    "docker": {
      "files": [
        "Dockerfile pour le backend (FastAPI)",
        "Dockerfile pour le frontend (Nginx)",
        "docker-compose.yml pour orchestrer backend, frontend et PostgreSQL"
      ],
      "instructions": "1. Cr\u00e9er un Dockerfile multi-stage pour le backend avec Python 3.10. 2. Cr\u00e9er un Dockerfile pour le frontend avec Nginx. 3. Configurer docker-compose.yml avec 3 services: backend, frontend, db. 4. Ajouter un volume pour la base de donn\u00e9es. 5. Configurer les variables d'environnement pour chaque service."
    }
  },
  "cloud": "D\u00e9ploiement local pour le d\u00e9veloppement, cible potentielle: AWS ECS ou Vercel pour le frontend"
}